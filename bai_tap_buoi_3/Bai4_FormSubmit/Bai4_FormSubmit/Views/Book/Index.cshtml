@model List<Bai4_FormSubmit.Models.Book>

<h2>Book List</h2>

<table border="1" cellpadding="10">

    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Price</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>
                <a href="/Book/Detail/@item.Id">Detail</a>
            </td>
        </tr>
    }

</table>