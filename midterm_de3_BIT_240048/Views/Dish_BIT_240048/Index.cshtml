@model IEnumerable<midterm_de3_BIT_240048.Models.Dish_BIT_240048>

@{
    ViewData["Title"] = "Danh sách món ăn";
}

<h1>Danh sách món ăn</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Thêm món ăn
    </a>
</p>

<form method="get">

    <div class="row mb-3">

        <div class="col-md-3">
            <input type="text"
                   name="searchString"
                   value="@ViewBag.SearchString"
                   class="form-control"
                   placeholder="Tên món ăn..." />
        </div>

        <div class="col-md-2">
            <select name="categoryId" class="form-control">
                <option value="">Tất cả loại</option>

                @foreach (var category in ViewBag.Categories)
                {
                    if (ViewBag.CategoryId != null &&
                        ViewBag.CategoryId == category.Id)
                    {
                        <option value="@category.Id" selected>
                            @category.Name
                        </option>
                    }
                    else
                    {
                        <option value="@category.Id">
                            @category.Name
                        </option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="isAvailable" class="form-control">
                <option value="">Tất cả</option>
                <option value="true"
                        selected="@(ViewBag.IsAvailable?.ToString() == "True")">
                    Đang bán
                </option>

                <option value="false"
                        selected="@(ViewBag.IsAvailable?.ToString() == "False")">
                    Ngừng bán
                </option>
            </select>
        </div>

        <div class="col-md-2">
            <input type="number"
                   name="minPrice"
                   value="@ViewBag.MinPrice"
                   class="form-control"
                   placeholder="Giá từ" />
        </div>

        <div class="col-md-2">
            <input type="number"
                   name="maxPrice"
                   value="@ViewBag.MaxPrice"
                   class="form-control"
                   placeholder="Giá đến" />
        </div>

        <div class="col-md-2 mt-2">
            <select name="sortOrder" class="form-control">
                <option value="">Mặc định</option>
                <option value="price_asc"
                        selected="@(ViewBag.SortOrder == "price_asc")">
                    Giá tăng dần
                </option>

                <option value="price_desc"
                        selected="@(ViewBag.SortOrder == "price_desc")">
                    Giá giảm dần
                </option>

                <option value="time_asc"
                        selected="@(ViewBag.SortOrder == "time_asc")">
                    TG chế biến tăng dần
                </option>
            </select>
        </div>

        <div class="col-md-2 mt-2">
            <button type="submit"
                    class="btn btn-success">
                Lọc
            </button>
        </div>

    </div>

</form>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Tên món</th>
            <th>Giá</th>
            <th>Thời gian</th>
            <th>Phân loại</th>
            <th>Trạng thái</th>
            <th>Loại món</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Name</td>

                <td>@item.Price</td>

                <td>@item.PreparationTime phút</td>

                <td>
                    @(item.PreparationTime <= 15
                        ? "Nhanh"
                        : "Thông thường")
                </td>

                <td>
                    @(item.IsAvailable
                        ? "Đang bán"
                        : "Ngừng bán")
                </td>

                <td>
                    @item.DishCategory?.Name
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.Id">
                        Edit
                    </a>

                    |

                    <a asp-action="Details"
                       asp-route-id="@item.Id">
                        Details
                    </a>

                    |

                    <a asp-action="Delete"
                       asp-route-id="@item.Id">
                        Delete
                    </a>
                </td>

            </tr>
        }

    </tbody>

</table>