@model List<bai_tap_buoi_6.Models.Student>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2>Danh sách sinh viên</h2>

<a asp-action="Create">Thêm sinh viên</a>

<table border="1">
    <tr>
        <th>Id</th>
        <th>Tên</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Chức năng</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Email</td>
            <td>@item.Phone</td>
            <td>
                <a asp-action="Detail" asp-route-id="@item.Id">Chi tiết</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                <a asp-action="Delete"
                asp-route-id="@item.Id"
                onclick="return confirm('Bạn có chắc muốn xóa?')">
                    Xóa
                </a>
            </td>
        </tr>
    }
</table>