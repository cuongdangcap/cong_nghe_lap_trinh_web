@model BIT_240048.Models.Dish_BIT240048

@{
    ViewData["Title"] = "Create";
}

<h1>Thêm món ăn</h1>

<h4>Dish_BIT240048</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">
                    Tên món ăn
                </label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label">
                    Giá
                </label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PreparationTime" class="control-label">
                    Thời gian chế biến (phút)
                </label>
                <input asp-for="PreparationTime" class="form-control" />
                <span asp-validation-for="PreparationTime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="IsAvailable" class="form-check-input" />
                    <label asp-for="IsAvailable" class="form-check-label">
                        Đang bán
                    </label>
                </div>
                <span asp-validation-for="IsAvailable" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label">
                    Mô tả
                </label>
                <textarea asp-for="Description"
                          class="form-control"
                          rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DishCategoryId" class="control-label">
                    Loại món ăn
                </label>

                <select asp-for="DishCategoryId"
                        class="form-control"
                        asp-items="ViewBag.DishCategoryId">
                    <option value="">
                        -- Chọn loại món ăn --
                    </option>
                </select>

                <span asp-validation-for="DishCategoryId"
                      class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit"
                       value="Thêm món ăn"
                       class="btn btn-primary" />
                <a asp-action="Index"
                   class="btn btn-secondary">
                    Quay lại
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}