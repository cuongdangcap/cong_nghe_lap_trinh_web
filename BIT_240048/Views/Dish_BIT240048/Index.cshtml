@model IEnumerable<BIT_240048.Models.Dish_BIT240048>

@{
    ViewData["Title"] = "Danh sách món ăn";
}

<h1>Danh sách món ăn</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm món ăn</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Tên món</th>
            <th>Giá</th>
            <th>Thời gian chế biến</th>
            <th>Đang bán</th>
            <th>Mô tả</th>
            <th>Loại món ăn</th>
            <th width="180">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>

                <td>@item.Price</td>

                <td>@item.PreparationTime phút</td>

                <td>
                    @(item.IsAvailable ? "✔" : "✘")
                </td>

                <td>@item.Description</td>

                <td>
                    @item.DishCategory?.Name
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Chi tiết
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>