@page
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Trang tin tức</title>

    <style>
        body{
            margin:0;
            font-family: Arial;
        }

        .container{
            width:1200px;
            margin:auto;
        }

        .menu{
            display:flex;
            gap:20px;
            padding:20px 0;
            border-bottom:1px solid #ccc;
        }

        .menu a{
            text-decoration:none;
            color:black;
            font-size:18px;
        }

        .top-news{
            display:flex;
            gap:30px;
            margin-top:20px;
        }

        .top-news img{
             width:600px;
             height:320px;
             object-fit:cover;
        }

        .top-content h1{
            font-size:28px;
            line-height:1.4;
        }

        .top-content p{
            color:#555;
            font-size:20px;
            line-height:1.5;
        }

        .bottom-news{
            display:flex;
            gap:20px;
            margin-top:40px;
        }

        .card{
            width:33%;
            overflow:hidden;
        }

        .card img{
            width:100%;
            height:180px;
            object-fit:cover;
            margin-top:10px;
        }

        .card h2{
            font-size:16px;
            line-height:1.5;
        }

        .sidebar{
            background:#f3f3f3;
            padding:20px;
            height:220px;
        }

    </style>
</head>

<body>

<div class="container">

    <div class="menu">
        <a href="#">Thời sự</a>
        <a href="#">Thế giới</a>
        <a href="#">Kinh doanh</a>
        <a href="#">Khoa học</a>
        <a href="#">Giải trí</a>
        <a href="#">Thể thao</a>
    </div>

    <div class="top-news">

        <img src="~/images/1.jpg" />

        <div class="top-content">
            <h1>
                'Ưu tiên tái định cư trước khi triển khai Trục cảnh quan sông Hồng'
            </h1>

            <p>
                Hà Nội sẽ ưu tiên xây dựng các khu tái định cư trước khi triển khai dự án lớn ven sông Hồng.
            </p>

            <span>1h trước</span>
        </div>

    </div>

    <div class="bottom-news">

        <div class="card">
            <h2>Hà Nội giải phóng mặt bằng cho hơn 1.400 dự án</h2>

            <img src="~/images/2.jpg" />
        </div>

        <div class="card">
            <h2>TP HCM siết kiểm soát người nhập cảnh phòng Ebola</h2>

            <img src="~/images/3.jpg" />
        </div>

        <div class="card sidebar">

            <h2>Góc nhìn</h2>

            <p>
                'Bóc lột' trên YouTube
            </p>

        </div>

    </div>

</div>

</body>
</html>